@unpublished{shu2026posturewaypoint,
  abbr     = {Under Review},
  title    = {From End-Effector Targets to Whole-Arm Postures: Configuration-Space Waypoint Recovery for Reactive Manipulation},
  author   = {Shu, Yiwei and Wang, Shuquan},
  year     = {2026},
  month    = jul,
  note     = {Under review at IEEE Robotics and Automation Letters.<ul class="items mt-2"><li>Developed PostureWaypoint to lift Cartesian bypass targets into collision-free, joint-feasible whole-arm configurations without global replanning or task-specific training.</li><li>Combined SDF-based bypass generation, SQP/Gauss-Newton posture synthesis, reactive control, and a progress-preserving CBF-QP safety filter in a 50 Hz pipeline averaging 2.73 ms per step.</li><li>Achieved a 70.2 percent mean whole-arm success rate across four manipulators and six tasks, with 20/20 success in both RM75 hardware tasks.</li></ul>},
  preview  = {posturewaypoint.jpg},
  video    = {/assets/video/posturewaypoint-demo.mp4},
  website  = {/projects/posturewaypoint/},
  selected = {true}
}

@unpublished{shu2026finite,
