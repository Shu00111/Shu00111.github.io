  title    = {Finite-State Visual Servo Control for Autonomous Target Landing of Low-Cost Underactuated Fixed-Wing Aircraft},
  author   = {Shu, Yiwei and Wang, Shuquan},
  year     = {2026},
  month    = jun,
  note     = {Under review at Aerospace Science and Technology.<ul class="items mt-2"><li>Developed a finite-state controller that switches from IMU-guided ascent to monocular vision-guided descent for target landing under limited sensing and weak control authority.</li><li>Designed and integrated a 189 g aircraft, onboard electronics, actuation, and adjustable launcher for CNY 534 without GPS, an airspeed sensor, or high-grade inertial navigation.</li><li>Built a CFD-informed simulation-to-flight pipeline that reduced normalized final image-plane radial error from 0.5049 to 0.0027 and achieved 20/20 real-world landings.</li></ul>},
  preview  = {finite-state-visual-servo.jpg},
  website  = {/projects/fixed-wing-landing/},
  selected = {true}
}

